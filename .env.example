# OpenAI API Key used by DSPy to query Language Models for compilation.
# Ensure this account has sufficient billing for high-throughput automated calls.
# Example: sk-proj-...
OPENAI_API_KEY=

# Optional LangChain telemetry key for external observability integrations.
# Example: lsv2_pt_...
LANGCHAIN_API_KEY=

# Optional Groq API Key if routing DSPy through groq endpoints for optimized token generation speed.
# Example: gsk_...
GROQ_API_KEY=

# Required token for LocalStack Pro features if your AWS templates rely on non-free-tier services.
# Example: ls-kiZAHEre...
LOCALSTACK_AUTH_TOKEN=
