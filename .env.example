# .env.example

# Controls the primary verification model instance and the native Semantic Evaluator.
# Expected format: sk-...
OPENAI_API_KEY=your_openai_api_key_here

# Fallback key utilized for dispatching test evaluation runs to secondary LLM clusters dynamically.
# Expected format: sk-or-v1-...
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LocalStack Ultimate authorization token enabling dynamic Phase 2 Local IAM Enforcement.
# Expected format: ls-...
LOCALSTACK_AUTH_TOKEN=your_localstack_token_here
